root = true

[*]
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
charset = utf-8

[*.java]
ij_java_names_count_to_use_import_on_demand = 999
ij_java_class_count_to_use_import_on_demand = 999

[*.yml]
indent_size = 2

[*.xml]
indent_size = 2

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false